{
  "name": "gemini-code-reviewer",
  "version": "1.0.2",
  "description": "AI-powered code reviewer using Google Gemini, with smart file scanning and best-practices injection.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gemini-code-reviewer": "dist/presentation/cli/main.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/presentation/cli/main.js",
    "dev": "ts-node --esm src/presentation/cli/main.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "clean": "rimraf dist"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "gemini",
    "ai",
    "code-review",
    "cli",
    "google"
  ],
  "author": "Mohamed Bouattour",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MohamedBouattour/Gemini-Code-Reviwer.git"
  },
  "bugs": {
    "url": "https://github.com/MohamedBouattour/Gemini-Code-Reviwer/issues"
  },
  "homepage": "https://github.com/MohamedBouattour/Gemini-Code-Reviwer#readme",
  "dependencies": {
    "@google/gemini-cli-core": "^0.30.0",
    "@google/genai": "^1.0.0",
    "@typescript-eslint/typescript-estree": "^8.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "google-auth-library": "^10.6.1",
    "open": "^11.0.0",
    "ora": "^8.1.0",
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "jiti": "^2.6.1",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.9",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
