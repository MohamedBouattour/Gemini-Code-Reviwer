{
  "name": "gemini-code-reviewer",
  "version": "1.0.0",
  "description": "AI-powered code reviewer using Google Gemini, with smart file scanning and best-practices injection.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gemini-code-reviewer": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/cli.js",
    "dev": "ts-node --esm src/cli.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "clean": "rimraf dist"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "gemini",
    "ai",
    "code-review",
    "cli",
    "google"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fast-glob": "^3.3.2",
    "google-auth-library": "^9.11.0",
    "marked": "^12.0.0",
    "marked-terminal": "^7.1.0",
    "open": "^11.0.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.2",
    "rimraf": "^5.0.9",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
